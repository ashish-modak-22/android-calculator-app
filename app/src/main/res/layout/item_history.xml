<?xml version="1.0" encoding="utf-8"?>

<!-- This layout will be for a single history card that will be shown through recycler viewer -->
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingBottom="8dp"
    android:paddingTop="8dp">

    <!-- Container for the history cards -->
    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/history_card_bg"
        android:paddingStart="22dp"
        android:paddingBottom="18dp"
        android:paddingTop="18dp"
        android:paddingEnd="22dp">

        <!-- Showing up the calculated expressions -->
        <TextView
            android:id="@+id/tvHistoryExpression"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/history_expression"
            android:textSize="17sp"
            android:gravity="end"
            android:fontFamily="sans-serif-light"/>

        <TextView
            android:id="@+id/tvHistoryResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/history_accent"
            android:textSize="30sp"
            android:textStyle="bold"
            android:gravity="end"
            android:paddingTop="4dp"
            android:fontFamily="sans-serif-medium"/>

    </androidx.appcompat.widget.LinearLayoutCompat>

</androidx.appcompat.widget.LinearLayoutCompat>

